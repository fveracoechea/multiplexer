{
  "name": "multiplexer",
  "version": "0.0.0",
  "description": "A tmux-based orchestration tool/MCP server for coding agents.",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/index.ts",
    "db:generate": "drizzle-kit generate",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint",
    "format": "biome format --write",
    "fix": "biome check --write",
    "check": "bun run typecheck && biome check && bun test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@types/bun": "1.3.14",
    "drizzle-kit": "^0.31.10",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "drizzle-orm": "^0.45.2",
    "zod": "^4.4.3"
  }
}
